{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg0_h":    "#1d2021",
    "bg0":      "#282828",
    "bg1":      "#3c3836",
    "bg2":      "#504945",
    "bg3":      "#665c54",
    "bg4":      "#7c6f64",
    "fg0":      "#fbf1c7",
    "fg1":      "#ebdbb2",
    "fg2":      "#d5c4a1",
    "fg3":      "#bdae93",
    "fg4":      "#a89984",
    "red":      "#fb4934",
    "red_dim":  "#cc241d",
    "green":    "#b8bb26",
    "green_dim":"#98971a",
    "yellow":   "#fabd2f",
    "yellow_dim":"#d79921",
    "blue":     "#83a598",
    "blue_dim": "#458588",
    "purple":   "#d3869b",
    "purple_dim":"#b16286",
    "aqua":     "#8ec07c",
    "aqua_dim": "#689d6a",
    "orange":   "#fe8019",
    "orange_dim":"#d65d0e",
    "gray":     "#928374"
  },
  "theme": {
    "primary":        { "dark": "orange",   "light": "orange_dim" },
    "secondary":      { "dark": "blue",     "light": "blue_dim" },
    "accent":         { "dark": "aqua",     "light": "aqua_dim" },
    "error":          { "dark": "red",      "light": "red_dim" },
    "warning":        { "dark": "yellow",   "light": "yellow_dim" },
    "success":        { "dark": "green",    "light": "green_dim" },
    "info":           { "dark": "blue",     "light": "blue_dim" },
    "text":           { "dark": "fg1",      "light": "bg0" },
    "textMuted":      { "dark": "fg4",      "light": "bg3" },
    "background":     { "dark": "bg0_h",   "light": "fg0" },
    "backgroundPanel":{ "dark": "bg0",      "light": "fg1" },
    "backgroundElement":{ "dark": "bg1",    "light": "fg2" },
    "border":         { "dark": "bg2",      "light": "bg3" },
    "borderActive":   { "dark": "orange",   "light": "orange_dim" },
    "borderSubtle":   { "dark": "bg1",      "light": "fg3" },

    "diffAdded":      { "dark": "green",    "light": "green_dim" },
    "diffRemoved":    { "dark": "red",      "light": "red_dim" },
    "diffContext":    { "dark": "fg4",      "light": "bg3" },
    "diffHunkHeader": { "dark": "blue",     "light": "blue_dim" },
    "diffHighlightAdded":   { "dark": "green",  "light": "green_dim" },
    "diffHighlightRemoved": { "dark": "red",    "light": "red_dim" },
    "diffAddedBg":          { "dark": "#32361a","light": "#dfe5b7" },
    "diffRemovedBg":        { "dark": "#3c1f1e","light": "#f2d2cf" },
    "diffContextBg":        { "dark": "bg0",    "light": "fg1" },
    "diffLineNumber":       { "dark": "bg3",    "light": "fg3" },
    "diffAddedLineNumberBg":   { "dark": "#32361a","light": "#dfe5b7" },
    "diffRemovedLineNumberBg": { "dark": "#3c1f1e","light": "#f2d2cf" },

    "markdownText":         { "dark": "fg1",     "light": "bg0" },
    "markdownHeading":      { "dark": "orange",  "light": "orange_dim" },
    "markdownLink":         { "dark": "blue",    "light": "blue_dim" },
    "markdownLinkText":     { "dark": "aqua",    "light": "aqua_dim" },
    "markdownCode":         { "dark": "green",   "light": "green_dim" },
    "markdownBlockQuote":   { "dark": "gray",    "light": "gray" },
    "markdownEmph":         { "dark": "yellow",  "light": "yellow_dim" },
    "markdownStrong":       { "dark": "orange",  "light": "orange_dim" },
    "markdownHorizontalRule":{ "dark": "bg3",    "light": "bg3" },
    "markdownListItem":     { "dark": "orange",  "light": "orange_dim" },
    "markdownListEnumeration":{ "dark": "aqua",  "light": "aqua_dim" },
    "markdownImage":        { "dark": "purple",  "light": "purple_dim" },
    "markdownImageText":    { "dark": "aqua",    "light": "aqua_dim" },
    "markdownCodeBlock":    { "dark": "fg1",     "light": "bg0" },

    "syntaxComment":     { "dark": "gray",    "light": "gray" },
    "syntaxKeyword":     { "dark": "red",     "light": "red_dim" },
    "syntaxFunction":    { "dark": "green",   "light": "green_dim" },
    "syntaxVariable":    { "dark": "blue",    "light": "blue_dim" },
    "syntaxString":      { "dark": "yellow",  "light": "yellow_dim" },
    "syntaxNumber":      { "dark": "purple",  "light": "purple_dim" },
    "syntaxType":        { "dark": "aqua",    "light": "aqua_dim" },
    "syntaxOperator":    { "dark": "orange",  "light": "orange_dim" },
    "syntaxPunctuation": { "dark": "fg2",     "light": "bg1" }
  }
}
